<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <style>
    body {
      font-family: Arial, sans-serif;
      line-height: 1.6;
      color: #333;
      max-width: 600px;
      margin: 0 auto;
      padding: 20px;
    }
    .header {
      background-color: #0070d2;
      color: white;
      padding: 20px;
      border-radius: 5px 5px 0 0;
    }
    .content {
      background-color: #f4f4f4;
      padding: 20px;
      border: 1px solid #ddd;
      border-top: none;
    }
    .field {
      margin-bottom: 15px;
    }
    .field-label {
      font-weight: bold;
      color: #555;
    }
    .field-value {
      margin-top: 5px;
      padding: 10px;
      background-color: white;
      border-left: 3px solid #0070d2;
    }
    .metadata {
      margin-top: 20px;
      padding: 10px;
      background-color: #e8e8e8;
      border-radius: 3px;
      font-size: 0.9em;
    }
    .footer {
      margin-top: 20px;
      padding-top: 20px;
      border-top: 1px solid #ddd;
      font-size: 0.85em;
      color: #777;
    }
  </style>
</head>
<body>
  <div class="header">
    <h2>New User Feedback Received</h2>
  </div>

  <div class="content">
    <div class="field">
      <div class="field-label">Submitted:</div>
      <div class="field-value">
        <%= @timestamp.strftime("%B %d, %Y at %I:%M %p %Z") %>
      </div>
    </div>

    <div class="field">
      <div class="field-label">Feedback Message:</div>
      <div class="field-value">
        <%= simple_format(h(@feedback_message)) %>
      </div>
    </div>

    <% if @context.present? %>
      <div class="metadata">
        <div class="field-label">Context Information:</div>
        <ul>
          <% @context.each do |key, value| %>
            <li><strong><%= key.to_s.humanize %>:</strong> <%= value %></li>
          <% end %>
        </ul>
      </div>
    <% end %>
  </div>

  <div class="footer">
    <p>This is an automated message from SAP Cloud Infrastructure Elektra.</p>
    <p>Please do not reply directly to this email.</p>
  </div>
</body>
</html>
