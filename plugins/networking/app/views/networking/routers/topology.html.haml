/ = content_for :title do
/   Show

.modal-body.networking
  #graph

  / Load D3 v3 from vendor directory since it requires global context
  = javascript_include_tag "d3.v3.min"
  :javascript
    // Wait for D3 to load before initializing topology
    (function checkD3() {
      if (typeof d3 !== 'undefined') {
        try {
          new networking.Topology("#graph",#{sanitize(@topology_graph.to_json)}, {details_url: "#{plugin('networking').router_node_details_path(@router.id)}"});
        } catch(e) {
          console.log('Error in Topology',e)
        }
      } else {
        setTimeout(checkD3, 50);
      }
    })();

- if modal?
  .modal-footer
    - if modal?
      %button.btn.btn-default{type:"button", data: {dismiss:"modal"}, aria: {label: "Close"}} Close
    - else
      = link_to "Close", networks_url(), class: 'btn btn-default'
